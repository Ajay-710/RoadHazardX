    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "build:admin": "cd RoadHazeX_Admin && npm run build",
        "deploy:admin": "npm run build:admin && npx -p firebase-tools firebase deploy --only hosting:admin",
