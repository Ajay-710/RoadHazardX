        "@capacitor/core": "^8.3.1",
        "@capacitor/geolocation": "^8.2.0",
        "@carbon/icons-react": "^11.78.0",
        "@clerk/clerk-react": "^5.60.0",
        "@mapbox/polyline": "^1.2.1",
